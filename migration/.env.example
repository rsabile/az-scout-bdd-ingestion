# ADX connection
ADX_CLUSTER_URI=https://az-pricing-tool-adx.germanywestcentral.kusto.windows.net
ADX_DATABASE_NAME=pricing-metrics
# ADX_TENANT_ID=          # Set if you are a guest in the tenant

# Azure Blob Storage (for CSV export/import)
# Connection string for ADX .export command
# Format: https://<account>.blob.core.windows.net/<container>;SecretKey=<key>
BLOB_STORAGE_CONN_STR=

# For csv_to_pg.py blob source
BLOB_ACCOUNT_URL=https://<account>.blob.core.windows.net
BLOB_CONTAINER_NAME=adx-export
BLOB_PREFIX=pricing_metrics
# BLOB_SAS_TOKEN=         # Alternative to DefaultAzureCredential

# PostgreSQL connection
POSTGRES_HOST=az-scout-pg.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=azscout
POSTGRES_USER=azscout
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=require
